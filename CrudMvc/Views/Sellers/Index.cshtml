@model IEnumerable<CrudMvc.Models.Seller>
@{
    
}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">Vendedores</h2>
        <a asp-action="Create" class="btn btn-primary">+ Novo </a>
    </div>
    <table class="table table-striped table-dark table-hover mb-0">
        <thead>
            <tr class="success">
                <th>
                    @Html.DisplayNameFor(model => model.Name)
                </th>

                <th >
                    @Html.DisplayNameFor(model => model.Email)
                </th>

                <th>
                    @Html.DisplayNameFor(model => model.BirthDate)
                </th>

                <th>
                    @Html.DisplayNameFor(model => model.BaseSalary)
                </th>
                
                <th class="text-end">
                    Ações
                </th>

            </tr>
            
        </thead>
        <tbody>
            @foreach (var modelo in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(Item => modelo.Name)

                    </td>
                    <td>
                        @Html.DisplayFor(Item => modelo.Email)

                    </td>
                    <td>
                        @Html.DisplayFor(Item => modelo.BirthDate)

                    </td>
                    <td>
                        @Html.DisplayFor(Item => modelo.BaseSalary)

                    </td>
                    
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@modelo.Id" class="btn btn-sm btn-outline-warning">Editar</a>
                        <a asp-action="Details" asp-route-id="@modelo.Id" class="btn btn-sm btn-outline-info">Detalhes</a>
                        <a asp-action="Delete" asp-route-id="@modelo.Id" class="btn btn-sm btn-outline-danger">Deletar</a>
                    </td>
                </tr>
            }


        </tbody>
    </table>
</div>