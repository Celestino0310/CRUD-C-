@{
    ViewData["Title"] = "Search";
}

<h1>Index</h1>

<div class="container py-4">
    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card shadow-sm border-0">

                <div class="card-header bg-dark text-white py-3">
                    <h5 class="mb-0 fw-semibold">Simple Search</h5>
                </div>

                <div class="card-body p-4">
                    <form asp-action="SimpleSearch">
                        <fieldset>
                            
                          
                            <div class=" mb-3">

                                <label for="minDate" class="control-label">Min. Date</label>
                                <div>
                                    <input type="date" name="minDate" class="form-control" />
                                </div>
                                
                               
                            </div>
                            <div class=" mb-3">

                                <label for="maxDate" class="control-label">Max. Date</label>
                                <div>
                                    <input type="date" name="maxDate" class="form-control" />
                                </div>
                                
                               
                            </div>
                            <div>
                                <button type="submit" class="btn btn-primary">Search</button>
                            </div>
                        </fieldset>
                    </form>
                </div>
            </div>
        
            <div class="card shadow-sm border-0 mt-4">
                <div class="card-header bg-dark text-white py-3">
                    <h5 class="mb-0 fw-semibold">Grouping Search</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="GroupingSearch">
                        <div class="mb-3">
                            <label for="minDate" class="form-label fw-semibold">Min. Date</label>
                            <input type="date" name="minDate" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label for="maxDate" class="form-label fw-semibold">Max. Date</label>
                            <input type="date" name="maxDate" class="form-control" />
                        </div>
                        <button type="submit" class="btn btn-primary">Search</button>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
