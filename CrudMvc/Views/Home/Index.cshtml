@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center py-5">
    <h1 class="display-4 fw-bold">Welcome to My CRUD</h1>
    <p class="lead text-muted">Minha primeira aplicação Web com Banco de Dados.</p>
</div>

<div class="row justify-content-center g-3 pb-5">
    <div class="col-md-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <span class="display-6 fw-bold text-primary">C</span>
                <div>
                    <h5 class="mb-0 fw-semibold">Create</h5>
                    <small class="text-muted">Criar novos registros</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <span class="display-6 fw-bold text-success">R</span>
                <div>
                    <h5 class="mb-0 fw-semibold">Read</h5>
                    <small class="text-muted">Consultar registros</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <span class="display-6 fw-bold text-warning">U</span>
                <div>
                    <h5 class="mb-0 fw-semibold">Update</h5>
                    <small class="text-muted">Atualizar registros</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <span class="display-6 fw-bold text-danger">D</span>
                <div>
                    <h5 class="mb-0 fw-semibold">Delete</h5>
                    <small class="text-muted">Remover registros</small>
                </div>
            </div>
        </div>
    </div>
</div>